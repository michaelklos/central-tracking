{
  "name": "central-tracking",
  "version": "0.1.9",
  "description": "Extensible task and time tracking application with plugin architecture for external source integration",
  "main": "dist/main/main.js",
  "bin": {
    "ct": "dist/cli/cli/main.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "build:main": "tsc -p tsconfig.main.json",
    "build:cli": "webpack --config webpack.cli.config.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build": "npm run build:main && npm run build:renderer && npm run build:cli",
    "start": "electron dist/main/main.js",
    "start:debug": "electron dist/main/main.js --debug",
    "pack": "npm run build && electron-builder --dir",
    "build:icons": "node scripts/build-icons.js",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "pretest": "node scripts/ensure-node-sqlite.js",
    "test": "vitest run",
    "posttest": "npx electron-rebuild -f -w better-sqlite3 2>/dev/null; exit 0",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "docs": "npm run build:cli && node scripts/generate-cli-docs.js",
    "docs:check": "npm run build:cli && node scripts/generate-cli-docs.js --check"
  },
  "build": {
    "appId": "com.centraltracking.app",
    "productName": "Central Tracking",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/file-uri-to-path/**/*",
      "**/node_modules/koffi/**/*",
      "dist/cli/cli/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "afterSign": "scripts/notarize.js",
    "mac": {
      "icon": "assets/mac/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/win/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "scripts/installer.nsh"
    }
  },
  "dependencies": {
    "@types/yargs": "17.0.35",
    "better-sqlite3": "^12.0.0",
    "koffi": "^2.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.7.0",
    "uuid": "^10.0.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@resvg/resvg-js": "^2.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.2",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.8.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^28.1.0",
    "png-to-ico": "^2.1.8",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.16",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
