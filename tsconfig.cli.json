{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/cli",
    "rootDir": "src",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/cli/**/*"],
  "exclude": ["src/cli/**/__tests__/**", "src/cli/**/*.test.ts"]
}
